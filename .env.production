# Production build env (used by `vite build` on Vercel). No secrets here — these
# VITE_* values are inlined into the public client bundle.

# Live Go backend on Render.
VITE_API_BASE=https://bingo-api-c6un.onrender.com

# Blank → WS base is derived from VITE_API_BASE (wss://bingo-api-c6un.onrender.com).
VITE_WS_BASE=

# Telegram bot username (without @). Must match the bot whose Mini App opens this site.
VITE_BOT_USERNAME=Habtam_bingobot

# Dev-only shims — MUST be off in production so real Telegram initData is used.
VITE_DEV_TELEGRAM_SHIM=0
VITE_DEV_MOCK_AUTH=0

# House deposit account shown on the deposit screen.
VITE_TELEBIRR_NUMBER=0997709691
VITE_PAYMENT_NAME=Habesha Bingo
