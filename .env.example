# Copy to .env.local for local dev.

# Backend REST base (no trailing slash). Local Go API runs on :8000.
VITE_API_BASE=http://localhost:8000

# WebSocket base. Usually the same host as VITE_API_BASE with ws/wss scheme.
# Leave blank to derive automatically from VITE_API_BASE.
VITE_WS_BASE=

# Telegram bot username (without @) — used for the "open the bot" deep link
# shown to users who aren't registered yet, and for referral share links.
VITE_BOT_USERNAME=HubBingoBot

# Set to "1" to enable the local dev shim that fakes Telegram initData when the
# app is opened in a normal browser (outside Telegram). NEVER enable in prod.
VITE_DEV_TELEGRAM_SHIM=1

# Set to "1" to fully mock login (fake user + wallet, no backend call) so the
# whole UI is browsable in a normal browser and Practice mode is playable.
# NEVER enable in prod.
VITE_DEV_MOCK_AUTH=1

# House deposit accounts shown to players on the deposit screen (NOT secrets —
# this is where players send money). Set the real values for production, and
# keep them in sync with the backend's VERIFY_TELEBIRR_ACCOUNT /
# VERIFY_CBEBIRR_ACCOUNT / VERIFY_MPESA_ACCOUNT — the verifier only
# auto-approves receipts credited to those exact accounts. Leaving a method's
# number empty hides that method from the deposit/withdraw pickers.
VITE_TELEBIRR_NUMBER=09XXXXXXXX
VITE_CBEBIRR_NUMBER=
VITE_MPESA_NUMBER=07XXXXXXXX
VITE_PAYMENT_NAME=Habesha Bingo
# Optional per-method holder names (default to VITE_PAYMENT_NAME):
# VITE_CBEBIRR_NAME=
# VITE_MPESA_NAME=
